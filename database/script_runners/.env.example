# PostgreSQL connection parameters for migration runner
# Copy this file to .env and fill in your values.
# The .env file is excluded from version control.
#
# Use workshopadmin_admin credentials here (migrations need DDL privileges).
# Use workshopadmin_app credentials in your backend appsettings.json.

PGHOST=localhost
PGPORT=5432
PGDATABASE=workshopadmin
PGUSER=workshopadmin_admin
PGPASSWORD=
